# Development is isolated from production by port and storage root.
MARKETCOW_PROFILE=development
MARKETCOW_HOST=127.0.0.1
MARKETCOW_PORT=8791
MARKETCOW_QUOTE_CACHE_TTL_SECONDS=60
MARKETCOW_QUOTE_STALE_MAX_SECONDS=604800
MARKETCOW_QUOTE_REFRESH_WORKERS=8
MARKETCOW_HOME=./data-development

# Stage 1 PostgreSQL metadata backend is opt-in and development-only.
MARKETCOW_METADATA_BACKEND=duckdb
MARKETCOW_POSTGRES_DSN=postgresql://marketcow:marketcow@127.0.0.1:5432/marketcow_development
# ClickHouse schema initialization is opt-in, loopback-only, and development/test-only.
MARKETCOW_CLICKHOUSE_ENABLED=false
MARKETCOW_CLICKHOUSE_HOST=127.0.0.1
MARKETCOW_CLICKHOUSE_PORT=8123
MARKETCOW_CLICKHOUSE_DATABASE=marketcow_development
MARKETCOW_CLICKHOUSE_USERNAME=default
MARKETCOW_CLICKHOUSE_PASSWORD=
MARKETCOW_CLICKHOUSE_SECURE=false
MARKETCOW_CLICKHOUSE_BATCH_SIZE=5000
MARKETCOW_CLICKHOUSE_SOURCE_PRIORITY=tushare,sina,eastmoney,yahoo_chart,baostock
MARKETCOW_CLICKHOUSE_CANONICAL_REL_TOL=1e-6
MARKETCOW_CLICKHOUSE_CANONICAL_ABS_TOL=1e-9
MARKETCOW_MARKET_BAR_READ_BACKEND=duckdb
MARKETCOW_RAW_MARKET_BAR_READ_BACKEND=duckdb
MARKETCOW_CLICKHOUSE_AUTO_CANONICAL=false
MARKETCOW_CLICKHOUSE_AUTO_CANONICAL_LIMIT=50000
# Background canonical is independent, default-off, and mutually exclusive with
# synchronous AUTO_CANONICAL. It is development-only and uses one bounded worker.
MARKETCOW_CLICKHOUSE_BACKGROUND_CANONICAL=false
MARKETCOW_CLICKHOUSE_SCHEDULER_QUEUE_CAP=1000
MARKETCOW_CLICKHOUSE_SCHEDULER_SCAN_LIMIT=100
MARKETCOW_CLICKHOUSE_SCHEDULER_POLL_SECONDS=1.0
MARKETCOW_CLICKHOUSE_SCHEDULER_BACKOFF_BASE_SECONDS=1.0
MARKETCOW_CLICKHOUSE_SCHEDULER_BACKOFF_MAX_SECONDS=60.0
MARKETCOW_CLICKHOUSE_SCHEDULER_MAX_ATTEMPTS=10
MARKETCOW_MARKET_BAR_CACHE_FRESHNESS_SECONDS=900
# Optional: omit/leave empty to atomically generate a persistent local key under storage_root.
MARKETCOW_MARKET_BAR_CURSOR_SECRET=
MARKETCOW_MARKET_BAR_CURSOR_TTL_SECONDS=3600
MARKETCOW_CLICKHOUSE_SPOOL=./data-development/spool/clickhouse
MARKETCOW_CLICKHOUSE_SPOOL_QUOTA_BYTES=1073741824
MARKETCOW_CLICKHOUSE_SPOOL_WARNING_RATIO=0.8
MARKETCOW_CLICKHOUSE_CONNECT_TIMEOUT=2.0
MARKETCOW_CLICKHOUSE_READ_TIMEOUT=5.0
MARKETCOW_POSTGRES_SCHEMA=marketcow_development

# Development may use a separate upstream key or inherit one from common .env.
TUSHARE_TOKEN=
TUSHARE_BASE_URL=https://fastapic.stockai888.top
TUSHARE_REALTIME_URL=https://realtime.stockai888.top
TUSHARE_MIN_INTERVAL=0.5
