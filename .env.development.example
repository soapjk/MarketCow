# Development is isolated from production by port and storage root.
MARKETCOW_PROFILE=development
MARKETCOW_HOST=127.0.0.1
MARKETCOW_PORT=8791
MARKETCOW_HOME=./data-development

# Development may use a separate upstream key or inherit one from common .env.
TUSHARE_TOKEN=
TUSHARE_BASE_URL=https://fastapic.stockai888.top
TUSHARE_REALTIME_URL=https://realtime.stockai888.top
TUSHARE_MIN_INTERVAL=0.5
