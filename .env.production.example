MARKETCOW_PROFILE=production
MARKETCOW_HOST=127.0.0.1
MARKETCOW_PORT=8790
MARKETCOW_HOME=/Volumes/T9/projects/marketcow/data-production
MARKETCOW_ALLOWED_ROOT=/Volumes/T9/projects/marketcow
MARKETCOW_POSTGRES_DSN_REF=MARKETCOW_POSTGRES_DSN
MARKETCOW_POSTGRES_DSN=postgresql://USER:PASSWORD@127.0.0.1:5432/marketcow_production
MARKETCOW_POSTGRES_SCHEMA=marketcow_production
MARKETCOW_CLICKHOUSE_HOST=127.0.0.1
MARKETCOW_CLICKHOUSE_PORT=8123
MARKETCOW_CLICKHOUSE_DATABASE=marketcow_production
MARKETCOW_CLICKHOUSE_USERNAME=marketcow
MARKETCOW_CLICKHOUSE_PASSWORD_REF=MARKETCOW_CLICKHOUSE_PASSWORD
MARKETCOW_CLICKHOUSE_PASSWORD=replace-me
MARKETCOW_CLICKHOUSE_BACKGROUND_CANONICAL=true
TUSHARE_TOKEN=
MARKETCOW_LONGPORT_APP_KEY=
MARKETCOW_LONGPORT_APP_SECRET=
MARKETCOW_LONGPORT_ACCESS_TOKEN=
MARKETCOW_QUOTE_PERSISTENCE_QUEUE_SIZE=256
MARKETCOW_QUOTE_PERSISTENCE_SHUTDOWN_SECONDS=5
