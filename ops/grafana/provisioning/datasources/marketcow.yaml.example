apiVersion: 1

# Copy this file into the local Grafana provisioning root through
# ops/grafana/provision_local.py. Secrets are deliberately not committed.
datasources:
  - name: MarketCow ClickHouse
    uid: marketcow-clickhouse
    type: grafana-clickhouse-datasource
    access: proxy
    isDefault: true
    jsonData:
      host: 127.0.0.1
      port: 18192
      protocol: http
      username: marketcow_grafana
      defaultDatabase: marketcow_production
      secure: false
    secureJsonData:
      password: ${MARKETCOW_GRAFANA_CLICKHOUSE_PASSWORD}

  - name: MarketCow PostgreSQL
    uid: marketcow-postgres
    type: postgres
    access: proxy
    url: 127.0.0.1:55492
    user: marketcow_grafana
    jsonData:
      database: marketcow_production
      sslmode: disable
      postgresVersion: 1600
      timescaledb: false
    secureJsonData:
      password: ${MARKETCOW_GRAFANA_POSTGRES_PASSWORD}
