MARKETCOW_PROFILE=v2-production
MARKETCOW_HOST=127.0.0.1
MARKETCOW_PORT=8790
MARKETCOW_HOME=/Volumes/T9/projects/marketcow/data-v2-production
MARKETCOW_V2_ALLOWED_ROOT=/Volumes/T9/projects/marketcow
MARKETCOW_POSTGRES_DSN_REF=MARKETCOW_V2_POSTGRES_DSN
MARKETCOW_V2_POSTGRES_DSN=postgresql://USER:PASSWORD@127.0.0.1:5432/marketcow_production
MARKETCOW_POSTGRES_SCHEMA=marketcow_production
MARKETCOW_CLICKHOUSE_ENABLED=true
MARKETCOW_CLICKHOUSE_HOST=127.0.0.1
MARKETCOW_CLICKHOUSE_PORT=8123
MARKETCOW_CLICKHOUSE_DATABASE=marketcow_production
MARKETCOW_CLICKHOUSE_USERNAME=marketcow
MARKETCOW_CLICKHOUSE_PASSWORD_REF=MARKETCOW_V2_CLICKHOUSE_PASSWORD
MARKETCOW_V2_CLICKHOUSE_PASSWORD=replace-me
MARKETCOW_CLICKHOUSE_BACKGROUND_CANONICAL=true
